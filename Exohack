-------------------------------------------------
-- LOGIQUE SCAM & GLITCH (5X répétition / 0.05s)
-------------------------------------------------
local function doScam(mode, repeats)
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if root and pingPosition then
        for i = 1, repeats do
            local originalCFrame = root.CFrame
            
            -- TP AU PING
            root.CFrame = CFrame.new(pingPosition) * originalCFrame.Rotation
            task.wait(0.05) -- 50ms
            
            -- RETOUR
            if mode == "normal" then
                root.CFrame = originalCFrame
            elseif mode == "left" then
                root.CFrame = originalCFrame * CFrame.new(-10, 0, 0)
            elseif mode == "right" then
                root.CFrame = originalCFrame * CFrame.new(10, 0, 0)
            end
            task.wait(0.05)
        end
    end
end

-- Connexions
