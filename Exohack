-------------------------------------------------
-- RESTE DU SCRIPT (FLY, NOCLIP, PING)
-------------------------------------------------
local bodyVel, bodyGyro
local function updateFly()
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    if flyEnabled then
        bodyVel = Instance.new("BodyVelocity", root)
        bodyVel.MaxForce = Vector3.new(1e6, 1e6, 1e6)
        bodyGyro = Instance.new("BodyGyro", root)
        bodyGyro.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
        char.Humanoid.PlatformStand = true
    else
        if bodyVel then bodyVel:Destroy() bodyVel = nil end
        if bodyGyro then bodyGyro:Destroy() bodyGyro = nil end
        char.Humanoid.PlatformStand = false
    end
end

flyBtn.MouseButton1Click:Connect(function() flyEnabled = not flyEnabled updateFly() end)
noclipBtn.MouseButton1Click:Connect(function() noclipEnabled = not noclipEnabled noclipBtn.Text = noclipEnabled and "Noclip : ON" or "Noclip : OFF" end)

RunService.RenderStepped:Connect(function()
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    if noclipEnabled then
        for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end
    end
    if flyEnabled and bodyVel and bodyGyro then
        local cam = workspace.CurrentCamera
        bodyVel.Velocity = (char.Humanoid.MoveDirection.Magnitude > 0) and (cam.CFrame.LookVector * flySpeed) or Vector3.new(0,0,0)
        bodyGyro.CFrame = cam.CFrame
    end
end)

pingBtn.MouseButton1Click:Connect(function()
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if root then
        pingPosition = root.Position
        if pingPart then pingPart:Destroy() end
        pingPart = Instance.new("Part", workspace)
        pingPart.Size = Vector3.new(2, 2, 2)
        pingPart.Position = pingPosition
        pingPart.Anchored = true
        pingPart.CanCollide = false
        pingPart.Color = Color3.fromRGB(255, 0, 0)
        pingPart.Material = Enum.Material.Neon
        pingPart.Shape = Enum.PartType.Ball
        Instance.new("Highlight", pingPart).FillColor = Color3.fromRGB(255, 0, 0)
    end
end)

