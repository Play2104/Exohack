-------------------------------------------------
-- LOGIQUE SCAM & GLITCH
-------------------------------------------------
local function doScam(mode, repeats)
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if root and pingPosition then
        for i = 1, repeats do
            local currentCFrame = root.CFrame
            root.CFrame = CFrame.new(pingPosition) * currentCFrame.Rotation
            task.wait(tempsSurCible)
            if mode == "normal" then
                root.CFrame = currentCFrame
            elseif mode == "left" then
                root.CFrame = currentCFrame * CFrame.new(-caseDistance, 0, 0)
            elseif mode == "right" then
                root.CFrame = currentCFrame * CFrame.new(caseDistance, 0, 0)
            end
            if repeats > 1 then task.wait(tempsSecurite) end
        end
    end
end

glitchL.MouseButton1Click:Connect(function() doScam("left", 5) end)
glitchR.MouseButton1Click:Connect(function() doScam("right", 5) end)
quickScam.MouseButton1Click:Connect(function() doScam("normal", 1) end)

-------------------------------------------------
-- LOGIQUE FLY AMÉLIORÉE (Joystick + Caméra)
-------------------------------------------------
local bodyVel, bodyGyro
local function updateFly()
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    if flyEnabled then
        bodyVel = Instance.new("BodyVelocity", root)
        bodyVel.MaxForce = Vector3.new(1e6, 1e6, 1e6)
        bodyGyro = Instance.new("BodyGyro", root)
        bodyGyro.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
        char.Humanoid.PlatformStand = true
    else
        if bodyVel then bodyVel:Destroy() bodyVel = nil end
        if bodyGyro then bodyGyro:Destroy() bodyGyro = nil end
        char.Humanoid.PlatformStand = false
    end
end

quickFly.MouseButton1Click:Connect(function() 
    flyEnabled = not flyEnabled 
    quickFly.BackgroundTransparency = flyEnabled and 0 or 0.3
    updateFly() 
end)

quickNoc.MouseButton1Click:Connect(function() 
    noclipEnabled = not noclipEnabled 
    quickNoc.BackgroundTransparency = noclipEnabled and 0 or 0.3
end)

RunService.RenderStepped:Connect(function()
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChild("Humanoid")
    if not root or not hum then return end

    if noclipEnabled then
        for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end
    end

    if flyEnabled and bodyVel and bodyGyro then
        local cam = workspace.CurrentCamera
        local moveDir = hum.MoveDirection
        
        if moveDir.Magnitude > 0 then
            -- On projette la direction du joystick dans l'orientation de la caméra
            -- Cela permet de monter si on regarde vers le haut et qu'on avance
            local look = cam.CFrame.LookVector
            local right = cam.CFrame.RightVector
            local up = cam.CFrame.UpVector
            
            -- Calcul de la vélocité 3D
            bodyVel.Velocity = (look * -hum.MoveDirection.Z + right * hum.MoveDirection.X + up * 0).Unit * flySpeed
            
            -- Petit correctif pour monter/descendre plus facilement avec l'angle de vue
            bodyVel.Velocity = (cam.CFrame:VectorToWorldSpace(Vector3.new(hum.MoveDirection.X, 0, hum.MoveDirection.Z))) * flySpeed
        else
            bodyVel.Velocity = Vector3.new(0, 0, 0)
        end
        bodyGyro.CFrame = cam.CFrame
    end
end)

