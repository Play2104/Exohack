-------------------------------------------------
-- LOGIQUE SCAM & GLITCH (Délai 1s au retour)
-------------------------------------------------
local function doScam(mode, repeats)
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if root and pingPosition then
        for i = 1, repeats do
            local currentCFrame = root.CFrame
            
            -- 1. TP AU PING (Attaque)
            root.CFrame = CFrame.new(pingPosition) * currentCFrame.Rotation
            task.wait(0.05) -- Très rapide sur la cible
            
            -- 2. RETOUR (Sécurité)
            if mode == "normal" then
                root.CFrame = currentCFrame
            elseif mode == "left" then
                root.CFrame = currentCFrame * CFrame.new(-10, 0, 0)
            elseif mode == "right" then
                root.CFrame = currentCFrame * CFrame.new(10, 0, 0)
            end
            
            -- 3. ATTENTE 1 SECONDE (Ta demande : délai avant le prochain saut)
            if repeats > 1 then
                task.wait(1) 
            end
        end
    end
end

-- Connexions
