pingBtn.MouseButton1Click:Connect(function()
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if root then
        pingPosition = root.Position
        if pingPart then pingPart:Destroy() end
        pingPart = Instance.new("Part", workspace)
        pingPart.Size = Vector3.new(2, 2, 2)
        pingPart.Position = pingPosition
        pingPart.Anchored = true
        pingPart.CanCollide = false
        pingPart.Color = Color3.fromRGB(255, 0, 0)
        pingPart.Material = Enum.Material.Neon
        pingPart.Shape = Enum.PartType.Ball
        Instance.new("Highlight", pingPart).FillColor = Color3.fromRGB(255, 0, 0)
    end
end)

tpBtn.MouseButton1Click:Connect(function()
    if pingPosition and player.Character then player.Character:MoveTo(pingPosition) end
end)
